{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 4,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["custom/gpu", "cpu", "disk", "network", "pulseaudio", "battery", "tray"],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },

    "sway/mode": {
        "format": "{}"
    },

    "clock": {
        "format": "  {:%H:%M:%S}",
        "format-alt": "  {:%Y-%m-%d %A}",
        "interval": 1,
        "tooltip-format": "<tt>{calendar}</tt>"
    },

    "cpu": {
        "format": "󰍛 {usage}%",
        "interval": 5,
        "tooltip": true
    },

    "disk": {
        "path": "/",
        "format": "󰋊 {used}",
        "interval": 60,
        "tooltip-format": "{used} used / {total} total ({percentage_used}%)"
    },

    "battery": {
        "bat": "BAT0",
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}% 󱐋 {power:0.1f}W",
        "format-charging": "󰂄 {capacity}% 󱐋 {power:0.1f}W",
        "format-plugged": "󰚥 {capacity}%",
        "format-full": "󰁹 FULL",
        "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "tooltip-format": "{timeTo}\n{capacity}% — {power:0.1f}W"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-icons": ["󰕿", "󰖀", "󰕾"],
        "format-muted": "󰝟 MUTE",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "custom/gpu": {
        "exec": "~/.config/waybar/scripts/gpu-usage.sh",
        "return-type": "json",
        "interval": 5,
        "format": "{}",
        "tooltip": true
    },

    "network": {
        "format-wifi": "󰤨 {signalStrength}%",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰤭 OFF",
        "tooltip-format-wifi": "{essid}\n{ipaddr}/{cidr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}",
        "interval": 5
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
